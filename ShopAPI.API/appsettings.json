{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=shopapi.db"
  },
  "Jwt": {
    "Key": "shopapi-super-secret-key-change-this-in-production-2026",
    "Issuer": "ShopAPI",
    "Audience": "ShopAPI.Client",
    "AccessTokenHours": 1,
    "RefreshTokenDays": 7
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379"
  },
  "RateLimiting": {
    "PermitLimit": 100
  },
  "StockAlert": {
    "Threshold": 10,
    "IntervalMinutes": 5
  },
  "Payments": {
    "Provider": "mock",
    "WebhookSecret": "shopapi-webhook-secret"
  },
  "Stripe": {
    "SecretKey": "",
    "FrontendUrl": "http://localhost:5173"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
